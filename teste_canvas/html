        <button onclick="scrollToSection('bases')" class="px-4 py-2 text-sm rounded-lg hover:bg-purple-500/20 transition">
            Bases
        </button>

        <button onclick="scrollToSection('mudanca')" class="px-4 py-2 text-sm rounded-lg hover:bg-purple-500/20 transition">
            Mudança de <br> Base
